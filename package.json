{
  "name": "@cinatra-ai/wordpress-mcp-connector",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "cinatra",
    "skills",
    "src",
    "!src/__tests__"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "test": "vitest"
  },
  "dependencies": {
    "@nangohq/frontend": "^0.70.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@cinatra-ai/sdk-extensions": "*",
    "@cinatra-ai/sdk-ui": "*"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    },
    "@cinatra-ai/sdk-ui": {
      "optional": true
    }
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "connector",
    "displayName": "WordPress MCP",
    "providesExternalMcpToolbox": true,
    "requestedHostPorts": [
      "nango"
    ],
    "dependencies": [],
    "capabilities": {
      "widget-chat.wordpress-content-editor": "wordpress-widget-chat"
    },
    "widgetStream": {
      "agentSlug": "wordpress-content-editor",
      "label": "WordPress",
      "subjectNoun": "post",
      "skillCapability": "widget-chat.wordpress-content-editor",
      "contextFields": [
        { "key": "instanceId", "maxLength": 64 },
        { "key": "postId", "maxLength": 32 },
        { "key": "postType", "maxLength": 32 },
        { "key": "postStatus", "maxLength": 32 },
        { "key": "href", "maxLength": 500 }
      ],
      "auth": {
        "tokenConfigKey": "wordpress_widget_auth",
        "instancesConfigKey": "wordpress",
        "requiredInstanceFields": ["id", "name", "username", "applicationPassword"]
      }
    }
  }
}
